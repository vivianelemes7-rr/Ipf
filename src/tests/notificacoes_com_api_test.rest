# Notificações comerciais — /notificacoes-com
# Pré-requisito: @funcionario_id (após cadastro/aprovação em testeFuncionario.rest)

@url_base = http://localhost:3000
@funcionario_id = 1
@notificacao_id = 1

### Processar atrasos (simular cron)
POST {{url_base}}/notificacoes-com/processar-atrasos
Content-Type: application/json

### SLA esperado: lead parado em Contato por mais de 7 dias
# Prepare um card em crm_comercial com etapa_kanban = "Contato" e data_entrada_etapa < NOW() - INTERVAL 7 DAY.
POST {{url_base}}/notificacoes-com/processar-atrasos
Content-Type: application/json

### SLA esperado: lead parado em Orcamento por mais de 7 dias após proposta
# Prepare um card em crm_comercial com etapa_kanban = "Orcamento" e data_entrada_etapa < NOW() - INTERVAL 7 DAY.
POST {{url_base}}/notificacoes-com/processar-atrasos
Content-Type: application/json

### Listar notificações do funcionário
GET {{url_base}}/notificacoes-com/{{funcionario_id}}
Accept: application/json

### Marcar notificação como lida
PATCH {{url_base}}/notificacoes-com/ler/{{notificacao_id}}
Content-Type: application/json

### Marcar todas como lidas
PATCH {{url_base}}/notificacoes-com/ler-tudo/{{funcionario_id}}
Content-Type: application/json

### Excluir notificação
DELETE {{url_base}}/notificacoes-com/{{notificacao_id}}
Accept: application/json
