# Próximo passo após cadastro: testeFuncionario.rest (aprovar usuário)

@url_base = http://localhost:3000
@email_teste = teste.usuario@ipf.com
@senha_teste = Senha123!
@email_admin = admin@ipf.com
@senha_admin = admin123
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..bdaUhxCEBQI_HF4CvZukIN9ucBgDGh8Oa1WLk0uwGlE
@admin_token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..C7aF-Ao2hpuTk56iJmEc_iiSdOgaqOiwvBDmNruucss

# ─── Setup e cadastro ───

### Criar primeiro Gerente (setup inicial)
POST {{url_base}}/auth/cadastrar-admin
Content-Type: application/json

{
  "nome": "Admin Geral",
  "email": "{{email_admin}}",
  "senha": "{{senha_admin}}"
}

### Cadastro público (usuário pendente)
POST {{url_base}}/auth/cadastrar
Content-Type: application/json

{
  "nome": "Teste Usuário",
  "email": "{{email_teste}}",
  "senha": "{{senha_teste}}"
}

### Cadastro Financeiro (usuário pendente)
POST {{url_base}}/auth/cadastrar
Content-Type: application/json

{
  "nome": "Financeiro",
  "email": "{{email_teste}}",
  "senha": "{{senha_teste}}"
}

### Cadastro vazio (erro esperado 422)
POST {{url_base}}/auth/cadastrar
Content-Type: application/json

{}

### Cadastro admin duplicado (erro esperado 409)
POST {{url_base}}/auth/cadastrar-admin
Content-Type: application/json

{
  "nome": "Admin Geral",
  "email": "{{email_admin}}",
  "senha": "{{senha_admin}}"
}

# ─── Login ───

### Login admin → @admin_token
POST {{url_base}}/auth/login
Content-Type: application/json

{
  "email": "{{email_admin}}",
  "senha": "{{senha_admin}}"
}

### Login usuário pendente (erro esperado 403)
POST {{url_base}}/auth/login
Content-Type: application/json

{
  "email": "{{email_teste}}",
  "senha": "{{senha_teste}}"
}

### Login senha incorreta (erro esperado 401)
POST {{url_base}}/auth/login
Content-Type: application/json

{
  "email": "{{email_teste}}",
  "senha": "SenhaErrada123"
}

### Login email inválido (erro esperado 422)
POST {{url_base}}/auth/login
Content-Type: application/json

{
  "email": "email-invalido",
  "senha": "{{senha_teste}}"
}

### Login usuário aprovado → @token (aprove em testeFuncionario.rest antes)
POST {{url_base}}/auth/login
Content-Type: application/json

{
  "email": "{{email_teste}}",
  "senha": "{{senha_teste}}"
}

