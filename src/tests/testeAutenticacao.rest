# ─── Recuperação de senha ───

### Esquecer senha
POST {{url_base}}/auth/esquecer-senha
Content-Type: application/json

{
  "email": "{{email_teste}}"
}

### Esquecer senha sem email (erro esperado 422)
POST {{url_base}}/auth/esquecer-senha
Content-Type: application/json

{}

# ─── Alterar senha (requer @token) ───

### Alterar senha (PATCH)
PATCH {{url_base}}/auth/alterar-senha
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "senhaAtual": "{{senha_teste}}",
  "senhaNova": "NovaSenha456!",
  "confirmarSenha": "NovaSenha456!"
}

### Alterar senha (POST)
POST {{url_base}}/auth/alterar-senha
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "senhaAtual": "NovaSenha456!",
  "senhaNova": "{{senha_teste}}",
  "confirmarSenha": "{{senha_teste}}"
}

### Alterar senha sem token (erro esperado 401)
PATCH {{url_base}}/auth/alterar-senha
Content-Type: application/json

{
  "senhaAtual": "{{senha_teste}}",
  "senhaNova": "NovaSenha456!",
  "confirmarSenha": "NovaSenha456!"
}

### Alterar senha — confirmação divergente (erro esperado 422)
PATCH {{url_base}}/auth/alterar-senha
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "senhaAtual": "{{senha_teste}}",
  "senhaNova": "NovaSenha456!",
  "confirmarSenha": "OutraSenha789!"
}
