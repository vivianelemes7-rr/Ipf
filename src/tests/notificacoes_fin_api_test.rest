# Notificações financeiras — /notificacoes-fin
# Pré-requisito: @funcionario_id (após cadastro/aprovação em testeFuncionario.rest)

@url_base = http://localhost:3000
@funcionario_id = 1
@notificacao_id = 1

### Verificar saúde do módulo financeiro (Health Check)
GET {{url_base}}/notificacoes-fin/health
Accept: application/json

### Processar atrasos (simular cron do financeiro)
POST {{url_base}}/notificacoes-fin/processar-atrasos
Content-Type: application/json

### Listar notificações do funcionário
GET {{url_base}}/notificacoes-fin/{{funcionario_id}}
Accept: application/json

### Marcar notificação como lida
PATCH {{url_base}}/notificacoes-fin/ler/{{notificacao_id}}
Content-Type: application/json

### Marcar todas como lidas
PATCH {{url_base}}/notificacoes-fin/ler-tudo/{{funcionario_id}}
Content-Type: application/json

### Excluir notificação
DELETE {{url_base}}/notificacoes-fin/{{notificacao_id}}
Accept: application/json