# Configuração de Ambiente - IPF CRM

# ========== BANCO DE DADOS ==========
# Aiven MySQL Credentials
DB_HOST=your-aiven-host.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=your_secure_password_here
DB_NAME=ipf_crm
DB_PORT=21306

# ========== SEGURANÇA ==========
# JWT Secret - OBRIGATORI: Gere uma string aleatória forte
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_aleatoria_forte_com_32_bytes_minimo

# ========== SERVIDOR ==========
PORT=3000
NODE_ENV=development

# ========== LOGS ==========
# Nível de logging: debug, info, warn, error
LOG_LEVEL=debug
